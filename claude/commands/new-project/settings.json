{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "model": "claude-sonnet-4-6",

  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(mise*)",
      "Bash(make*)",
      "Write(.mcp.json)",
      "Write(.claude/**)",
      "Write(agents/**)",
      "Write(guidelines/**)",
      "Write(docs/**)"
    ],
    "deny": []
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/on-session-start.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-bash.js"
          }
        ]
      }
    ],
    "PostToolUse": [],
    "Stop": []
  }
}
